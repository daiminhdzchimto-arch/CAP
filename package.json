{
  "name": "cap",
  "version": "1.0.0",
  "private": true,
  "description": "CAP pre-commit and commit lint tooling",
  "scripts": {
    "prepare": "husky",
    "precommit": "lint-staged",
    "lint:staged": "lint-staged",
    "commitlint": "commitlint --from HEAD~1 --to HEAD --verbose"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3"
  },
  "lint-staged": {
    "*.{html,css,js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
